---
import type { BlogPost } from "../../lib/blog";

import "../../styles/global.css";

import Navbar from "../layout/Navbar.astro";
import RightAside from "../layout/RightAside.astro";
import Sidebar from "../layout/Sidebar.astro";
import SiteHead from "../layout/SiteHead.astro";

interface Props {
  posts: BlogPost[];
  title: string;
  eyebrow: string;
  description: string;
  pageTitle?: string;
}

const { posts, title, eyebrow, description, pageTitle = `${title} | Ng` } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(date);

const cardClass =
  "rounded-card border border-border bg-card p-4 backdrop-blur-lg transition duration-200 hover:-translate-y-px hover:border-primary/30 hover:bg-white/82 dark:border-border-dark dark:bg-card-dark dark:hover:border-primary/30 dark:hover:bg-white/7 sm:p-5";
const tagClass =
  "rounded-pill border border-primary/16 bg-primary/8 px-2 py-1 text-xs font-medium leading-tight text-text-secondary transition-colors duration-200 hover:border-accent/28 hover:bg-accent/9 hover:text-text-primary dark:border-primary/18 dark:bg-primary/10 dark:text-text-secondary-dark dark:hover:border-accent/30 dark:hover:bg-accent/12 dark:hover:text-text-primary-dark";
---

<html lang="zh-CN">
  <head>
    <SiteHead title={title} description={description} />
  </head>
  <body class="min-h-screen">
    <Navbar />
    <main
      class="site-grid site-grid--page relative z-10 text-text-primary dark:text-text-primary-dark"
    >
      <div class="hidden min-w-0 min-[821px]:block min-[821px]:sticky min-[821px]:top-20">
        <Sidebar />
      </div>
      <div class="min-w-0">
        <header class="mb-10">
          <p class="m-0 text-xs font-bold uppercase leading-none tracking-[0.16em] text-text-muted dark:text-text-muted-dark">
            {eyebrow}
          </p>
          <h1 class="mt-3 text-3xl font-bold leading-tight tracking-[-0.06em] sm:text-5xl">{title}</h1>
          <p class="mt-4 max-w-2xl text-base leading-8 text-text-secondary dark:text-text-secondary-dark">
            {description}
          </p>
        </header>

        {
          posts.length > 0 ? (
            <section class="grid gap-4" aria-label={`${title}列表`}>
              {posts.map((post) => (
                <article class={`${cardClass} grid gap-3`}>
                  <div class="grid gap-2 sm:flex sm:items-start sm:justify-between sm:gap-4">
                    <h2 class="m-0 text-xl font-bold leading-8 tracking-[-0.04em]">
                      <a class="no-underline transition-colors duration-200 hover:text-accent" href={`/blog/${post.id}/`}>
                        {post.data.title}
                      </a>
                    </h2>
                    <time
                      class="shrink-0 text-xs leading-6 text-text-muted dark:text-text-muted-dark"
                      datetime={post.data.date.toISOString()}
                    >
                      {formatDate(post.data.date)}
                    </time>
                  </div>
                  <p class="m-0 text-sm leading-7 text-text-secondary dark:text-text-secondary-dark">
                    {post.data.description ?? "这篇文章暂无摘要，点击标题阅读全文。"}
                  </p>
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class={tagClass}>#{tag}</span>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </section>
          ) : (
            <section class={cardClass}>
              <h2 class="m-0 text-xl font-bold tracking-[-0.04em]">暂无文章</h2>
              <p class="mt-3 text-sm leading-7 text-text-secondary dark:text-text-secondary-dark">
                当前分类下还没有文章。
              </p>
            </section>
          )
        }
      </div>
      <div class="hidden min-w-0 min-[821px]:col-start-2 min-[821px]:block min-[1101px]:sticky min-[1101px]:top-20 min-[1101px]:col-auto">
        <RightAside />
      </div>
    </main>
    <details class="mobile-assist min-[821px]:hidden">
      <summary class="mobile-assist__toggle" aria-label="打开辅助信息">
        <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M12 5v14" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
        </svg>
      </summary>
      <div class="mobile-assist__panel scrollbar-thin">
        <div class="grid gap-3">
          <Sidebar />
          <RightAside />
        </div>
      </div>
    </details>
  </body>
</html>
