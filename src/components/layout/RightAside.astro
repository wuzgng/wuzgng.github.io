---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

const siteStartYear =
  posts.length > 0
    ? String(Math.min(...posts.map((post) => post.data.date.getFullYear())))
    : String(new Date().getFullYear());

const siteStats = [
  { label: "文章数量", value: String(posts.length) },
  { label: "标签数量", value: String(tags.length) },
  { label: "建站时间", value: siteStartYear },
];

const recentUpdates = posts.slice(0, 3).map((post) => ({
  title: post.data.title,
  href: `/blog/${post.id}/`,
}));

const cardClass =
  "rounded-card border border-border bg-card p-4 backdrop-blur-lg transition duration-200 hover:-translate-y-px hover:border-primary/30 hover:bg-white/82 dark:border-border-dark dark:bg-card-dark dark:hover:border-primary/30 dark:hover:bg-white/7";
const sectionTitleClass =
  "mb-3 text-xs font-bold uppercase leading-none tracking-[0.12em] text-text-muted dark:text-text-muted-dark";
---

<aside class="grid w-full content-start gap-4 text-text-primary dark:text-text-primary-dark" aria-label="网站辅助信息">
  <section class={cardClass} aria-labelledby="site-info-title">
    <h2 id="site-info-title" class={sectionTitleClass}>网站数据</h2>
    <div class="grid gap-3">
      {
        siteStats.map((stat) => (
          <div class="flex items-baseline justify-between gap-3">
            <span class="text-xl font-bold leading-none tracking-[-0.04em]">{stat.value}</span>
            <span class="text-sm text-text-secondary dark:text-text-secondary-dark">{stat.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class={cardClass} aria-labelledby="recent-updates-title">
    <h2 id="recent-updates-title" class={sectionTitleClass}>最新动态</h2>
    {
      recentUpdates.length > 0 ? (
        <ul class="m-0 grid list-none gap-3 p-0">
          {recentUpdates.map((item) => (
            <li>
              <a
                class="block text-sm leading-6 text-text-secondary no-underline transition-colors duration-200 hover:text-accent dark:text-text-secondary-dark"
                href={item.href}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="m-0 text-sm leading-6 text-text-secondary dark:text-text-secondary-dark">
          暂无动态
        </p>
      )
    }
  </section>
</aside>
