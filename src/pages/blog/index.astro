---
import { getCollection } from "astro:content";

import BlogListLayout from "../../components/blog/BlogListLayout.astro";
import { sortPostsByDateDesc } from "../../lib/blog";

const posts = sortPostsByDateDesc(await getCollection("blog", ({ data }) => !data.draft));
---

<BlogListLayout
  posts={posts}
  title="所有文章"
  eyebrow="Blog Archive"
  description="这里收录所有博客文章。\n技术的推演、项目的实践，以及生活的瞬间。"
  pageTitle="所有文章 | Ng"
/>
