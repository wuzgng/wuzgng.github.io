---
import { getCollection } from "astro:content";

import BlogListLayout from "../../components/blog/BlogListLayout.astro";
import { hasTag, sortPostsByDateDesc } from "../../lib/blog";

const posts = sortPostsByDateDesc(
  (await getCollection("blog", ({ data }) => !data.draft)).filter((post) =>
    hasTag(post, "技术"),
  ),
);
---

<BlogListLayout
  posts={posts}
  title="技术"
  eyebrow="Tech Archive"
  description="技术是对现实结构的拆解与重建。\n这里记录代码、系统、工具，以及那些让复杂问题变得可理解的过程。"
  pageTitle="技术 | Ng"
/>
