---
import { getCollection } from "astro:content";

import BlogListLayout from "../../components/blog/BlogListLayout.astro";
import { blogTagGroups, hasAnyTag, sortPostsByDateDesc } from "../../lib/blog";

const posts = sortPostsByDateDesc(
  (await getCollection("blog", ({ data }) => !data.draft)).filter((post) =>
    hasAnyTag(post, blogTagGroups.life),
  ),
);
---

<BlogListLayout
  posts={posts}
  title="生活"
  eyebrow="Life Archive"
  description="生活不刻意解释意义，它只是记录发生。\n这里记录日常的片段，以及那些值得留存的瞬间。"
  pageTitle="生活 | Ng"
/>
